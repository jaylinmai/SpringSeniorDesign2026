import speech_recognition as sr #need in every code for VR
from gpiozero import LED #need for GPIO useage and LED is local var. 
#from time import sleep

led = LED(17) #using pin 17 on GPIO

# Initialize the recognizer
r = sr.Recognizer()
mic = sr.Mircophone

while True: 
  with mic as source: 
      print("Say 'on' or 'off'") 
      audio = r.listen(source)
try: 
  text = r.recognize_google(audio)
    if text == "on": 
        led.on()
    if text == "off": 
        led.off()
    if text == "bye": 
    print("Goodbye")
except sr.UnknownValueError:
    print("Could not understand the audio.") 
except sr.RequestError as e:
print(f"Could not request results from Google API; {e}")
